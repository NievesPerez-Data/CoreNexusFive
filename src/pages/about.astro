---
import Layout from "../layouts/Layout.astro";
import miFoto from "../../public/foto-personal.jpg"; // Ajusta según tu estructura de carpetas
---

<Layout title="Demo y Entrega | Core Nexus Five">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap" rel="stylesheet">

  <div class="web-container">
      
      <!-- Barra lateral fija -->
      <aside class="sidebar">
          <div class="sidebar-card">
              <div class="profile-photo-container">
                <div class="photo-shadow"></div>
                  <img src={miFoto.src} alt="Nieves Pérez" class="profile-photo" />
              </div>

              <h1 class="sidebar-title font-fugaz">AWS DATA ANALYTICS & ARCHITECTURE</h1>
              <div class="sidebar-subtitle">DEMO & ENTREGA FINAL</div>
              
              <p class="sidebar-text">
                  Validación visual y dinámica de la arquitectura desplegada en Core Nexus Five. La culminación práctica de la infraestructura Cloud y la ingeniería de datos.
              </p>
              
              <a href="https://nievesperez-data.github.io/" class="portfolio-btn" target="_blank">
                  IR AL PORTAFOLIO PRINCIPAL &rarr;
              </a>
          </div>
      </aside>

      <!-- Contenido Principal -->
      <main class="content-flow">
          
          <!-- Bloque 1: Conclusión y Cierre -->
          <section class="block-card">
              <h2 class="section-title font-fugaz">DEMO Y ENTREGA FINAL</h2>
              <p class="block-text">
                  Esta sección constituye el cierre práctico de <strong>Core Nexus Five</strong>. Tras haber desglosado la teoría, las decisiones de diseño y la infraestructura, este espacio está dedicado a la validación en un entorno real. Es la consolidación de todo el proyecto resumida en una ejecución interactiva.
              </p>

              <!-- Nota manuscrita en el margen derecho -->
              <div class="side-note">
                  <svg class="marker-arrow" viewBox="0 0 120 80">
                    <path d="M-20,40 Q30,35 110,40" stroke="black" stroke-width="12" fill="none" stroke-linecap="round"/>
                    <path d="M85,20 L112,41 L85,60" stroke="black" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="handwritten-text">El despliegue en acción</span>
              </div>
          </section>

          <!-- Bloque 2: El Video Integrado (Reproductor nativo) -->
          <section class="block-card video-card">
              <h2 class="section-title font-fugaz">VALIDACIÓN EN VIVO (END-TO-END)</h2>
              <p class="block-text mb-6">
                  A continuación se observa, de manera limpia y fluida, cómo la arquitectura cobra vida: desde la ingesta del dato crudo en S3 hasta su transformación mediante AWS Glue y su disponibilidad final para analítica.
              </p>
              
              <!-- Contenedor responsive para el iframe de Dailymotion -->
              <div class="video-wrapper">
                  <iframe 
                      src="https://www.dailymotion.com/embed/video/xa8agkq?autoplay=0&mute=1" 
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                      allowfullscreen 
                      class="embedded-video"
                  ></iframe>
              </div>
          </section>

          <!-- Bloque 3: Redirección Destacada (Estilo featured-card de tu perfil) -->
          <section class="block-card featured-card">
              <h2 class="section-title font-fugaz">¿QUIERES PROFUNDIZAR EN LOS DETALLES TÉCNICOS?</h2>
              <p class="block-text">
                  Para mantener la claridad y dinamismo de esta demostración, no repetiremos aquí los pasos individuales. Si deseas analizar las entrañas del despliegue —como la auditoría de políticas IAM, el código de limpieza detallado en Python o las pruebas de concepto con múltiples consultas en Amazon Athena— puedes acceder de forma estructurada a cada toma de decisiones a través de nuestro <a href="/blog" class="blog-inline-link"><strong>Blog Técnico</strong></a>, diseñado como una guía de ingeniería inversa para estudiantes y profesionales del sistema.
              </p>

              <div class="side-note">
                  <svg class="marker-arrow" viewBox="0 0 120 80">
                    <path d="M-20,40 Q30,35 110,40" stroke="black" stroke-width="12" fill="none" stroke-linecap="round"/>
                    <path d="M85,20 L112,41 L85,60" stroke="black" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="handwritten-text">Manual paso a paso sin redundancias</span>
              </div>
          </section>

      </main>
  </div>
</Layout>

<style>
    body {
        overflow-x: hidden;
        margin: 0;
        padding: 0;
    }

    .web-container {
        max-width: 1400px;
        margin: 120px auto 40px auto;
        display: flex;
        gap: 40px;
        padding-right: 280px;
        box-sizing: border-box;
    }

    .sidebar {
        flex: 0 0 300px;
        position: sticky;
        top: 120px;
        height: fit-content;
    }

    .sidebar-card {
        border: 1px solid rgba(0, 0, 0, 0.15);
        background-color: #ffffff; 
        padding: 200px 30px 30px 30px;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .profile-photo-container {
        position: absolute;
        top: -60px;
        left: 50%;
        transform: translateX(-50%);
        width: 180px;
        height: 220px;
    }

    .photo-shadow {
        position: absolute;
        width: 100%;
        height: 100%;
        background: #d3d3d3;
        top: 15px;
        left: 15px;
        z-index: 1;
    }

    .profile-photo {
        position: relative;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border: 2px solid black;
        z-index: 2;
        display: block;
        background-color: white;
    }

    .sidebar-title {
        font-size: 22px;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-weight: 900;
        line-height: 1.1;
    }

    .sidebar-subtitle {
        font-size: 11px;
        font-weight: 700;
        color: #666;
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
    }

    .sidebar-text {
        font-size: 15px;
        line-height: 1.6;
        color: #333;
        margin-bottom: 25px;
    }

    .portfolio-btn {
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        color: #000;
        border-bottom: 2px solid #000;
        padding-bottom: 4px;
        display: inline-block;
        width: fit-content;
        text-transform: uppercase;
    }

    .content-flow {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 30px; 
        max-width: 900px;
    }

    .block-card {
        border: 1px solid rgba(0, 0, 0, 0.1);
        padding: 40px 50px;
        position: relative; 
        background-color: #ffffff;
    }

    .section-title {
        font-size: 18px;
        margin-bottom: 15px;
        color: #000;
        font-weight: 900;
        text-transform: uppercase;
    }

    .block-text {
        font-size: 16px;
        line-height: 1.6;
        color: #222;
    }

    .mb-6 {
        margin-bottom: 24px;
    }

    /* Estilos del reproductor integrado */
    .video-card {
        padding-bottom: 50px;
    }

    .video-wrapper {
        position: relative;
        padding-pb: 56.25%; /* Relación de aspecto 16:9 */
        height: 0;
        overflow: hidden;
        border: 2px solid #000000;
        box-shadow: 6px 6px 0px rgba(0, 0, 0, 0.05);
    }

    .embedded-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    /* Enlace integrado al blog */
    .blog-inline-link {
        color: #000000;
        text-decoration: none;
        border-bottom: 2px solid #000000;
        padding-bottom: 1px;
        transition: opacity 0.2s;
    }
    .blog-inline-link:hover {
        opacity: 0.7;
    }

    /* Notas laterales manuscritas */
    .side-note {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        right: -280px; 
        width: 250px; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        pointer-events: none;
    }

    .marker-arrow {
        width: 80px; 
        margin-left: -30px;
        overflow: visible;
    }

    .handwritten-text {
        font-family: 'Caveat', cursive;
        font-size: 40px; 
        font-weight: 700;
        color: #000;
        line-height: 0.85;
        padding-left: 15px;
        transform: rotate(-1deg);
        display: block;
    }

    @media (max-width: 1100px) {
        .web-container { 
            flex-direction: column; 
            padding-right: 20px; 
            padding-left: 20px;
        }
        .side-note { 
            position: relative; 
            right: 0; 
            top: 0; 
            width: 100%; 
            margin: 20px 0; 
            transform: none; 
        }
        .marker-arrow { 
            margin-left: 0; 
            transform: rotate(90deg); 
            width: 40px; 
        }
    }

    /* Tarjeta Destacada Final (Efecto Pulse) */
    .featured-card {
        border: 2px solid #000000 !important; 
        box-shadow: 10px 10px 0px rgba(0, 0, 0, 0.08); 
        animation: gentle-pulse 4s infinite ease-in-out;
    }

    .featured-card .handwritten-text {
        color: #000000;
        font-weight: 900;
    }

    @keyframes gentle-pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.015); 
            box-shadow: 14px 14px 0px rgba(0, 0, 0, 0.12); 
        }
    }
</style>
