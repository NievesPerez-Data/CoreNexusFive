---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Perfil Profesional | Core Nexus Five">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap" rel="stylesheet">

  <div class="web-container">
      
      <aside class="sidebar">
          <div class="sidebar-card">
              <div class="profile-photo-container">
                  <img src="/tu-foto-aqui.jpg" alt="Tu Nombre" class="profile-photo" />
              </div>

              <h1 class="sidebar-title font-fugaz">AWS DATA ANALYTICS & ARCHITECTURE</h1>
              <div class="sidebar-subtitle">SOBRE MÍ & ENFOQUE</div>
              
              <p class="sidebar-text">
                  Trayectoria centrada en transformar datos brutos en decisiones inteligentes. Combino experiencia en gestión de equipos y unidades de negocio con una formación técnica en Análisis de Datos, aportando nuevas competencias técnicas aplicadas a la nube.
              </p>
              
              <a href="https://nievesperez-data.github.io/" class="portfolio-btn" target="_blank">
                IR AL PORTAFOLIO PRINCIPAL &rarr;
              </a>
          </div>
      </aside>

      <main class="content-flow">
          <section class="block-card">
              <h2 class="section-title font-fugaz">Donde el dato encuentra su infraestructura</h2>
              <p class="block-text">
                  Mi trayectoria se centra en transformar datos brutos en decisiones estratégicas de impacto...
              </p>
              <div class="side-note">
                  <svg class="marker-arrow" viewBox="0 0 120 80">
                    <path d="M-20,40 Q30,35 110,40" stroke="black" stroke-width="12" fill="none" stroke-linecap="round"/>
                    <path d="M85,20 L112,41 L85,60" stroke="black" stroke-width="12" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="handwritten-text">Uniendo el 'qué' con el 'dónde'</span>
              </div>
          </section>

          </main>
  </div>
</Layout>

<style>
    /* Estilos base que ya tenías */
    .web-container {
        max-width: 1600px;
        margin: 40px 20px;
        display: flex;
        gap: 40px;
    }

    .sidebar {
        flex: 0 0 320px; /* Un poco más ancho para la foto */
        position: sticky;
        top: 40px;
        height: fit-content;
    }

    /* Estilos específicos para la FOTO */
    .profile-photo-container {
        width: 100px; /* Tamaño pequeño y elegante */
        height: 100px;
        margin-bottom: 20px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #000; /* Marco fino negro para encajar con el estilo */
    }

    .profile-photo {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Asegura que no se deforme */
    }

    .sidebar-card {
        border: 1px solid rgba(0, 0, 0, 0.15);
        background-color: #ffffff; 
        padding: 30px;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
    }

    .sidebar-title {
        font-size: 24px;
        margin-bottom: 10px;
        text-transform: uppercase;
        font-weight: 800;
        line-height: 1.1;
    }

    .sidebar-subtitle {
        font-size: 12px;
        font-weight: 700;
        color: #666;
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
    }

    .sidebar-text {
        font-size: 15px;
        line-height: 1.6;
        color: #333;
        margin-bottom: 25px;
    }

    .portfolio-btn {
        font-size: 14px;
        font-weight: 800;
        text-decoration: none;
        color: #000;
        border-bottom: 2px solid #000;
        padding-bottom: 5px;
        display: inline-block;
        width: fit-content;
    }

    .portfolio-btn:hover {
        opacity: 0.7;
    }

    /* Contenedor y flujo de bloques (Igual que antes) */
    .content-flow {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 30px; 
        max-width: 900px;
    }

    .block-card {
        border: 1px solid rgba(0, 0, 0, 0.1);
        padding: 40px 50px;
        position: relative; 
        background: transparent;
    }

    .side-note {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        right: -280px; 
        width: 250px; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .marker-arrow {
        width: 80px;
        margin-left: -30px;
    }

    .handwritten-text {
        font-family: 'Caveat', cursive;
        font-size: 45px; 
        font-weight: 700;
        line-height: 0.85;
    }
</style>
