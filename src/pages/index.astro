---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">
    
    <div class="relative hidden md:flex flex-1">
      <!-- IMAGEN DE FONDO: Asegúrate de que el nombre coincida exactamente -->
      <img 
        src="/nubes-fondo.JPG" 
        class="absolute inset-0 w-full h-full object-cover opacity-40 z-0"
        alt=""
      />

      <!-- TÍTULO: Misma tipografía y clases que el original -->
      <h1 class="max-w-[80%] text-[10rem] absolute text-center z-20 left-1/2 -translate-x-1/2 top-1/4 font-fugaz leading-none uppercase">
        Core Nexus Five
      </h1>

      <!-- SUBTÍTULO Y TEXTOS -->
      <div class="absolute z-20 bottom-1/3 left-1/2 -translate-x-1/2 text-center w-full">
        <p class="text-4xl font-bold tracking-tight uppercase mb-2">
          Proyecto Final AWS Re/Start
        </p>
        <p class="text-2xl font-light italic">
          El nexo entre la infraestructura y la analítica de datos.
        </p>
      </div>

      <!-- NOMBRE: Estilo original del p -->
      <div class="absolute bottom-1/4 left-1/2 -translate-x-1/2 z-20">
        <a href="https://nievesperez-data.github.io/" class="text-3xl font-medium border-b-2 border-black">
          Nieves Pérez
        </a>
      </div>
    </div>

    <HomeMob />

    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>
  </div>
</Layout>
