---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">
    
    <!-- Sección Izquierda: Identidad del Proyecto -->
    <div class="relative hidden md:flex flex-1 flex-col items-center justify-center text-center p-12 overflow-hidden bg-white">
      
      <!-- Fondo: Imagen de nubes -->
      <div class="absolute inset-0 z-0">
        <img 
          src="/nubes-fondo.JPG" 
          alt="" 
          class="w-full h-full object-cover opacity-30 shadow-inner"
        />
        <!-- Capa extra para suavizar el fondo si es muy fuerte -->
        <div class="absolute inset-0 bg-white/20"></div>
      </div>

      <!-- Título Principal (Un poco más grande: de 8xl a 9xl) -->
      <h1 class="text-8xl md:text-9xl font-fugaz leading-[0.9] uppercase mb-10 z-10 relative px-4 text-black tracking-tighter">
        Core Nexus Five
      </h1>

      <!-- Contenedor de Textos -->
      <div class="flex flex-col items-center gap-6 z-10 relative text-black">
        <p class="text-4xl font-bold tracking-tight uppercase">
          Proyecto Final AWS Re/Start
        </p>
        
        <p class="text-2xl font-light italic max-w-xl leading-relaxed">
          El nexo entre la infraestructura y la analítica de datos.
        </p>

        <!-- Tu Nombre -->
        <div class="mt-14">
          <a 
            href="https://nievesperez-data.github.io/" 
            class="text-3xl font-medium hover:opacity-50 transition-opacity duration-300 border-b-2 border-black pb-1"
          >
            Nieves Pérez
          </a>
        </div>
      </div>
    </div>

    <!-- Vista Móvil -->
    <HomeMob />

    <!-- Sección Derecha: Carrusel Visual -->
    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>

  </div>
</Layout>
