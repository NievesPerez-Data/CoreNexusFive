import Layout from "@/layouts/Layout.astro";

import HomeMob from "@/components/HomeMob.astro";

import VerticalCarousel from "@/components/react/VerticalCarousel";

---



<Layout>

  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">



      <!-- Título principal (mismo estilo que "Big City Life") -->

      <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">

        <div class="relative hidden md:flex flex-1">

          <h2

        class="max-w-96 text-9xl absolute text-center z-20 -right-32 bottom-1/3 font-fugaz uppercase leading-[0.8]"

      >

        Core Nexus Five

      </h2>



      <!-- Subtítulo -->

      <p class="text-xl absolute bottom-1/4 right-0 z-20 font-bold uppercase tracking-tight">

        Proyecto Final AWS Re/Start

      </p>



      <!-- Descripción -->

      <p class="text-lg absolute bottom-[20%] right-0 z-20 italic font-light">

        El nexo entre la infraestructura y la analítica de datos.

      </p>



      <!-- Enlace con tu nombre -->

      <a 

        href="[nievesperez-data.github.io](https://nievesperez-data.github.io/)" 

        class="text-xl absolute bottom-[15%] right-0 z-20 border-b-2 border-black pb-1"

      >

        Nieves Pérez

      </a>



    </div>



    <HomeMob />



    <div

      class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden"

    >

      <VerticalCarousel client:visible imageCount={10} />

    </div>

  </div>

</Layout>
