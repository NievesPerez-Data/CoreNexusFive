---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow text-white">
    
    <!-- Sección Izquierda: Identidad del Proyecto -->
    <div class="relative hidden md:flex flex-1 flex-col justify-center transition-all duration-500">
      
      <!-- Título Principal -->
      <h1 class="max-w-2xl text-8xl absolute z-20 -right-32 top-1/4 font-fugaz leading-tight uppercase tracking-tighter">
        Core <span class="text-blue-500">Nexus</span> Five
      </h1>

      <!-- Subtítulo y Frase -->
      <div class="absolute bottom-1/3 right-0 text-right flex flex-col gap-2">
        <p class="text-3xl font-bold tracking-tight text-gray-200 uppercase">
          Proyecto Final AWS Re/Start
        </p>
        <p class="text-xl font-light italic text-gray-400 max-w-md">
          El nexo entre la infraestructura y la analítica de datos.
        </p>
      </div>

      <!-- Tu Firma Personalizada -->
      <div class="absolute bottom-1/4 right-0 text-right">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-500 mb-1 font-semibold">
          Desarrollado por
        </p>
        <a 
          href="https://nievesperez-data.github.io/" 
          class="text-lg font-medium hover:text-blue-400 transition-colors duration-300 hover:underline decoration-blue-500 underline-offset-4"
        >
          Nieves Pérez
        </a>
      </div>
    </div>

    <!-- Vista Móvil -->
    <HomeMob />

    <!-- Sección Derecha: Carrusel Visual -->
    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>

  </div>
</Layout>
