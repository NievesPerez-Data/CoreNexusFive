---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">
    
    <!-- Sección Izquierda: Identidad del Proyecto -->
    <div class="relative hidden md:flex flex-1 flex-col items-center justify-center text-center">
      
      <!-- Título Principal (Más grande y centrado) -->
      <h1 class="text-9xl md:text-[11rem] font-fugaz leading-none uppercase mb-10">
        Core Nexus Five
      </h1>

      <!-- Contenedor de Textos -->
      <div class="flex flex-col items-center gap-4">
        <p class="text-4xl font-bold tracking-tight uppercase">
          Proyecto Final AWS Re/Start
        </p>
        
        <p class="text-xl font-light italic max-w-xl">
          El nexo entre la infraestructura y la analítica de datos.
        </p>

        <!-- Tu Nombre -->
        <div class="mt-12">
          <a 
            href="https://nievesperez-data.github.io/" 
            class="text-2xl font-medium hover:opacity-50 transition-opacity duration-300 border-b border-black"
          >
            Nieves Pérez
          </a>
        </div>
      </div>
    </div>

    <!-- Vista Móvil -->
    <HomeMob />

    <!-- Sección Derecha: Carrusel Visual -->
    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>

  </div>
</Layout>
