---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">
    
    <!-- Sección Izquierda: Identidad del Proyecto -->
    <div class="relative hidden md:flex flex-1 flex-col items-center justify-center text-center p-12 overflow-hidden">
      
      <!-- Imagen de Fondo del Título (Ajusta la ruta a tu imagen) -->
      <div class="absolute inset-0 z-0 flex items-center justify-center opacity-20 pointer-events-none">
        <img 
          src="/nubes-fondo.JPG" 
          alt="Background Decor" 
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Título Principal-->
      <h1 class="text-7xl md:text-8xl font-fugaz leading-tight uppercase mb-8 z-10 relative px-4">
        Core Nexus Five
      </h1>

      <!-- Contenedor de Textos -->
      <div class="flex flex-col items-center gap-4 z-10 relative">
        <p class="text-3xl font-bold tracking-tight uppercase">
          Proyecto Final AWS Re/Start
        </p>
        
        <p class="text-lg font-light italic max-w-md">
          El nexo entre la infraestructura y la analítica de datos.
        </p>

        <!-- Tu Nombre -->
        <div class="mt-10">
          <a 
            href="https://nievesperez-data.github.io/" 
            class="text-xl font-medium hover:opacity-50 transition-opacity duration-300 border-b border-black"
          >
            Nieves Pérez
          </a>
        </div>
      </div>
    </div>

    <!-- Vista Móvil -->
    <HomeMob />

    <!-- Sección Derecha: Carrusel Visual -->
    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>

  </div>
</Layout>
