---
import Layout from "@/layouts/Layout.astro";
import HomeMob from "@/components/HomeMob.astro";
import VerticalCarousel from "@/components/react/VerticalCarousel";
---

<Layout>
  <div class="md:flex-row flex flex-col md:gap-10 relative md:pr-72 grow">
    
    <!-- Contenedor Izquierdo Principal -->
    <div class="relative hidden md:flex flex-1 flex-col items-center justify-center text-center p-10">
      
      <!-- LA IMAGEN: Ahora con z-index negativo para que NADA la tape -->
      <div class="absolute inset-0 -z-10">
        <img 
          src="/nubes-fondo.JPG" 
          alt=""
          class="w-full h-full object-cover opacity-50"
        />
      </div>

      <!-- EL TÍTULO: Usando exactamente las clases del original pero con tu texto -->
      <h1 class="text-9xl font-fugaz uppercase leading-[0.8] mb-8">
        Core<br/>Nexus<br/>Five
      </h1>

      <!-- BLOQUE DE TEXTOS: Sin absolute para que no se amontonen -->
      <div class="flex flex-col gap-4">
        <p class="text-4xl font-bold tracking-tight uppercase">
          Proyecto Final AWS Re/Start
        </p>
        
        <p class="text-2xl font-light italic">
          El nexo entre la infraestructura y la analítica de datos.
        </p>

        <!-- TU NOMBRE: Con margen arriba para separar -->
        <div class="mt-8">
          <a 
            href="https://nievesperez-data.github.io/" 
            class="text-3xl font-medium border-b-2 border-black pb-1"
          >
            Nieves Pérez
          </a>
        </div>
      </div>
    </div>

    <HomeMob />

    <div class="min-h-screen md:w-1/2 -mt-50 md:mt-0 max-h-full overflow-hidden">
      <VerticalCarousel client:visible imageCount={10} />
    </div>

  </div>
</Layout>
  </div>
</Layout>
