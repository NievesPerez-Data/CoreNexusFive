.analogy-box { border-top: 1px solid #ddd; padding-top: 8px; }
.analogy-box .handwritten-title { font-family: 'Caveat', cursive; font-size: 24px; font-weight: 700; color: #000; }

/* --- SECCIÓN LÍNEAS ANIMADAS INTEGRALES --- */
.architecture-lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }

/* Línea Central: Flujo descendente grueso y continuo */
.main-map-line {
  fill: none;
  stroke: url(#data-flow-grad);
  stroke-width: 5.5;
}
.animated-main-flow {
  stroke-dasharray: 80 40;
  animation: mainFlow 4s linear infinite;
}
@keyframes mainFlow {
  to { stroke-dashoffset: -120; }
}

/* Líneas Laterales: Movimiento fluido */
.side-map-line { fill: none; stroke: url(#data-flow-grad); stroke-width: 3.8; }
.animated-flow {
  stroke-dasharray: 1000;
  stroke-dashoffset: 1000;
  animation: sideFlow 7s linear infinite;
}
@keyframes sideFlow {
  to { stroke-dashoffset: 0; }
}

/* NODOS CIRCULARES */
.node { position: absolute; left: 50%; transform: translateX(-50%); z-index: 5; cursor: pointer; }
.node-content {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2px solid #000000;
  box-sizing: border-box;
  padding: 15px;
  transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
}
.node:hover .node-content {
  box-shadow: 0 0 30px 10px rgba(255, 255, 255, 0.75);
  transform: scale(1.06);
}
.node-logo { width: 63%; height: 63%; object-fit: contain; }

/* --- BLOQUE DE TEXTO REESCALADO (MÁS PEQUEÑO) --- */
