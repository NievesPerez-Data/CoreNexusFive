}

/* COMPORTAMIENTO DE LAS FLECHAS GRUESAS MANUSCRITAS */
.marker-arrow { width: 50px; flex-shrink: 0; overflow: visible; }

/* NOTAS LATERALES CON MÁRGENES ADAPTATIVOS SEPARADOS DEL BORDE */
.map-side-note { position: absolute; top: 50%; transform: translateY(-50%); display: flex; align-items: center; pointer-events: none; gap: 14px; }

