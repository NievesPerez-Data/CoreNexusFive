    <span>HERMES</span>

    <div class="node-popup">
      <p>
        Glue conecta, transforma y transporta información.
        Hermes enlaza mundos separados mediante integración ETL.
      </p>
    </div>
  </div>

  <!-- ATHENA -->
  <div class="node node-medium node-athena">
    <img src="/athena-logo.png" alt="Athena" class="node-logo" />
    <h3>ATHENA</h3>
    <span>ATENEA</span>

    <div class="node-popup">
      <p>
        Athena permite consultar datos directamente sobre S3.
        Sabiduría instantánea extraída del caos.
      </p>
    </div>
  </div>

  <!-- DEMO -->
  <div class="node node-final">
    <img src="/demo-logo.png" alt="Demo" class="node-logo large-logo" />
