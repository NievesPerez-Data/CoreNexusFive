<section class="olimpo-container">

  <!-- SVG FLECHAS -->
  <svg class="lines-canvas" viewBox="0 0 1400 1400" preserveAspectRatio="none">

    <defs>
      <marker
        id="arrow"
        markerWidth="12"
        markerHeight="12"
        refX="10"
        refY="4"
        orient="auto"
      >
        <path d="M0,0 L0,8 L10,4 z" fill="#ffffff" />
      </marker>
    </defs>

    <!-- CERBERO -->
    <line x1="700" y1="120" x2="700" y2="220" class="line-path" marker-end="url(#arrow)" />

    <!-- ORIGEN -->
    <line x1="700" y1="320" x2="700" y2="420" class="line-path" marker-end="url(#arrow)" />

    <!-- S3 -->
    <line x1="700" y1="520" x2="700" y2="620" class="line-path" marker-end="url(#arrow)" />

    <!-- BUCKETS -->
    <line x1="700" y1="720" x2="700" y2="820" class="line-path" marker-end="url(#arrow)" />

    <!-- CRAWLERS -->
    <line x1="700" y1="920" x2="700" y2="1020" class="line-path" marker-end="url(#arrow)" />

    <!-- GLUE -> ATHENA -->
    <line x1="700" y1="1120" x2="700" y2="1220" class="line-path" marker-end="url(#arrow)" />

    <!-- ATHENA -> EFESTO -->
    <line x1="700" y1="1320" x2="700" y2="1420" class="line-path" marker-end="url(#arrow)" />

    <!-- ZEUS -->
    <line x1="950" y1="1120" x2="780" y2="1120" class="line-path" marker-end="url(#arrow)" />

  </svg>

  <!-- IAM -->
  <div class="node node-guardian" onclick="openModal('cerbero')">
    IAM
    <small>CERBERO</small>
  </div>

  <!-- ORIGEN -->
  <div class="node node-large" onclick="openModal('origen')">
    ORIGEN
  </div>

  <!-- S3 -->
  <div class="node node-main" onclick="openModal('gaia')">
    S3
    <small>GAIA</small>
  </div>

  <!-- BUCKETS -->
  <div class="node node-main" onclick="openModal('pandora')">
    BUCKETS
    <small>PANDORA</small>
  </div>

  <!-- CRAWLERS -->
  <div class="node node-main" onclick="openModal('argos')">
    CRAWLERS
    <small>ARGOS</small>
  </div>

  <!-- GLUE -->
  <div class="node node-main" onclick="openModal('hermes')">
    GLUE
    <small>HERMES</small>
  </div>

  <!-- ATHENA -->
  <div class="node node-main athena-node" onclick="openModal('athena')">
    ATHENA
    <small>ATENEA</small>
  </div>

  <!-- LAMBDA -->
  <div class="node node-side" onclick="openModal('zeus')">
    LAMBDA
    <small>ZEUS</small>
  </div>

  <!-- DEMO -->
  <div class="node node-demo" onclick="openModal('hefesto')">
    DEMO FINAL
    <small>EFESTO</small>
  </div>

</section>
