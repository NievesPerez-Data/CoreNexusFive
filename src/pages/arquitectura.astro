---

---

<section class="diagram">

  <div class="node" onclick="openModal('s3')">
    S3
  </div>

  <div class="node" onclick="openModal('glue')">
    Glue
  </div>

  <div class="node" onclick="openModal('athena')">
    Athena
  </div>

</section>

<!-- MODAL S3 -->
<div id="s3" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('s3')">&times;</span>

    <h2>Amazon S3</h2>

    <p>
      Almacenamiento principal de la arquitectura.
    </p>

    <ul>
      <li>Datos Raw</li>
      <li>Data Lake</li>
      <li>Escalable</li>
    </ul>
  </div>
</div>

<!-- MODAL GLUE -->
<div id="glue" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('glue')">&times;</span>

    <h2>AWS Glue</h2>

    <p>
      Servicio ETL utilizado para catalogar y transformar datos.
    </p>
  </div>
</div>

<!-- MODAL ATHENA -->
<div id="athena" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal('athena')">&times;</span>

    <h2>Amazon Athena</h2>

    <p>
      Consultas SQL serverless directamente sobre S3.
    </p>
  </div>
</div>

<script is:inline>
  function openModal(id) {
    document.getElementById(id).style.display = "flex";
  }

  function closeModal(id) {
    document.getElementById(id).style.display = "none";
  }

  window.openModal = openModal;
  window.closeModal = closeModal;
</script>

<style>
.diagram{
  display:flex;
  justify-content:center;
  gap:80px;
  padding:100px 20px;
}

.node{
  width:180px;
  height:180px;
  border-radius:50%;
  border:3px solid black;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  font-weight:bold;
  transition:.3s;
}

.node:hover{
  transform:scale(1.05);
}

.modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.7);
  justify-content:center;
  align-items:center;
  z-index:999;
}

.modal-content{
  background:white;
  width:700px;
  max-width:90%;
  padding:40px;
  border-radius:20px;
  position:relative;
}

.close{
  position:absolute;
  top:15px;
  right:20px;
  font-size:32px;
  cursor:pointer;
}
</style>
