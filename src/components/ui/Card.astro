---
// src/components/ui/Card.astro
const { post } = Astro.props;
---

<li class="border-2 border-black p-6 bg-white shadow-[8px_8px_0px_rgba(0,0,0,0.15)] flex flex-col gap-4 list-none">
  
  {post.data.heroImage && (
    <img 
      src={`/CoreNexusFive${post.data.heroImage}`} 
      alt={post.data.title} 
      class="w-full h-48 object-cover border-b-2 border-black"
    />
  )}

  <div class="flex flex-col gap-2">
    <span class="text-sm text-gray-600">
      {new Date(post.data.pubDate).toLocaleDateString('es-ES', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })}
    </span>

    <a href={`/CoreNexusFive/blog/${post.slug}/`} class="hover:underline">
      <h2 class="text-xl font-bold font-fugaz uppercase text-black block">
        {post.data.title}
      </h2>
    </a>

    <p class="text-gray-700 line-clamp-3 block">
      {post.data.description}
    </p>
  </div>
</li>
