---
import DeskNav from "@/components/react/DeskNav";
import SearchBar from "@/components/react/SearchBar";
import { getCollection } from "astro:content";

// Importaciones de imágenes estables de la carpeta public
import adalabLogo from "../../public/adalab-logo.png";
import awsRestartLogo from "../../public/aws-restart-logo.png";

const [blogEntries, collectionEntries] = await Promise.all([
  getCollection("blog"),
  getCollection("collection"),
]);

const searchItems = [
  ...blogEntries.map((p) => ({
    title: p.data.title as string,
    url: `/blog/${p.id}`,
    collection: "blog",
  })),
  ...collectionEntries.map((p) => ({
    title: p.data.title as string,
    url: `/collection/${p.id}`,
    collection: "collection",
  })),
];
---

<section
  class="hidden p-2 fixed right-6 md:flex flex-col w-2/12 py-10 justify-between h-full min-h-screen"
>
  <div class="flex justify-end relative z-10">
    <SearchBar items={searchItems} client:idle />
  </div>

  <DeskNav client:idle />

  {/* Contenedor inferior de logos y texto perfectamente centrado en columna */}
  <div class="flex flex-col items-center justify-end gap-6 relative z-10 w-16 ml-auto mb-6">
    
    {/* Texto vertical estilizado */}
    <div class="h-28 w-full flex items-center justify-center relative mb-2">
      <span 
        class="text-[10px] tracking-[0.3em] uppercase opacity-50 font-bold select-none whitespace-nowrap inline-block text-center text-neutral-800"
        style="transform: rotate(-90deg); width: 120px; min-width: 120px;"
      >
        Cradle & Context
      </span>
    </div>

    {/* Enlace + Recuadro contenedor de Adalab */}
    <a 
      href="https://adalab.es/" 
      target="_blank" 
      rel="noopener noreferrer"
      class="group opacity-90 hover:opacity-100 transition-all duration-300 w-14 h-14 flex items-center justify-center border border-neutral-300/80 bg-neutral-50/50 hover:bg-neutral-900 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-0.5"
      title="Adalab Tech Bootcamp"
    >
      <img 
        src={adalabLogo.src} 
        alt="Logo Adalab" 
        class="w-10 h-10 object-contain object-center grayscale group-hover:grayscale-0 group-hover:invert-0 transition-all duration-300" 
      />
    </a>

    {/* Enlace + Recuadro contenedor de AWS re/Start */}
    <a 
      href="https://aws.amazon.com/es/training/restart/" 
      target="_blank" 
      rel="noopener noreferrer"
      class="group opacity-90 hover:opacity-100 transition-all duration-300 w-14 h-14 flex items-center justify-center border border-neutral-300/80 bg-neutral-50/50 hover:bg-neutral-900 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-0.5"
      title="AWS re/Start Program"
    >
      <img 
        src={awsRestartLogo.src} 
        alt="Logo AWS re/Start" 
        class="w-10 h-10 object-contain object-center grayscale group-hover:grayscale-0 transition-all duration-300" 
      />
    </a>
    
  </div>
</section>
