---
import DeskNav from "@/components/react/DeskNav";
import SearchBar from "@/components/react/SearchBar";
import { getCollection } from "astro:content";

// IMPORTACIÓN DIRECTA: Traemos las imágenes resolviendo la ruta real desde la carpeta public
import adalabLogo from "../../../public/adalab-logo.png";
import awsRestartLogo from "../../../public/aws-restart-logo.jpg";

const [blogEntries, collectionEntries] = await Promise.all([
  getCollection("blog"),
  getCollection("collection"),
]);

const searchItems = [
  ...blogEntries.map((p) => ({
    title: p.data.title as string,
    url: `/blog/${p.id}`,
    collection: "blog",
  })),
  ...collectionEntries.map((p) => ({
    title: p.data.title as string,
    url: `/collection/${p.id}`,
    collection: "collection",
  })),
];
---

<section
  class="hidden p-2 fixed right-6 md:flex flex-col w-2/12 py-10 justify-between h-full min-h-screen"
>
  <div class="flex justify-end relative z-10">
    <SearchBar items={searchItems} client:idle />
  </div>

  <DeskNav client:idle />

  {/* Contenedor inferior de logos y texto perfectamente centrado en columna */}
  <div class="flex flex-col items-center justify-end gap-8 relative z-10 w-16 ml-auto mb-6">
    
    {/* Texto vertical estilizado */}
    <div class="h-28 w-full flex items-center justify-center relative">
      <span 
        class="text-[10px] tracking-[0.3em] uppercase opacity-50 font-bold select-none whitespace-nowrap inline-block text-center text-neutral-800"
        style="transform: rotate(-90deg); width: 120px; min-width: 120px;"
      >
        Cradle & Context
      </span>
    </div>

    {/* Enlace + Imagen de Adalab (Usa la referencia importada en los atributos) */}
    <a 
      href="https://adalab.es/" 
      target="_blank" 
      rel="noopener noreferrer"
      class="opacity-80 hover:opacity-100 transition-opacity w-full flex items-center justify-center"
      title="Adalab Tech Bootcamp"
    >
      <img 
        src={adalabLogo.src} 
        alt="Logo Adalab" 
        class="w-full max-w-[50px] h-auto object-contain object-center grayscale hover:grayscale-0 transition-all duration-300" 
      />
    </a>

    {/* Enlace + Imagen de AWS re/Start (Usa la referencia importada en los atributos) */}
    <a 
      href="https://aws.amazon.com/es/training/restart/" 
      target="_blank" 
      rel="noopener noreferrer"
      class="opacity-80 hover:opacity-100 transition-opacity w-full flex items-center justify-center"
      title="AWS re/Start Program"
    >
      <img 
        src={awsRestartLogo.src} 
        alt="Logo AWS re/Start" 
        class="w-full max-w-[55px] h-auto object-contain object-center grayscale hover:grayscale-0 transition-all duration-300" 
      />
    </a>
    
  </div>
</section>
