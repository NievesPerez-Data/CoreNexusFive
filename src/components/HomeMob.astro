---
// Importamos tus dos insignias de forma súper estable desde la raíz public
import adalabLogo from "../../public/adalab-logo.png";
import awsRestartLogo from "../../public/aws-restart-logo.png";
---

<section class="w-full flex flex-col md:hidden px-5 z-10 mb-5">
  <div class="flex justify-between items-center mt-10">
    <h1 class="text-5xl font-bold uppercase font-fugaz tracking-tight leading-tight">
      Core Nexus<br /> Five
    </h1>
    
    <button 
      id="mobile-menu-btn"
      class="p-3 bg-neutral-900 text-white rounded-xl shadow-md z-50 active:scale-95 transition-transform"
      aria-label="Ver Certificaciones"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  
  <p class="text-xl pt-6 font-semibold uppercase text-neutral-700">
    Proyecto Final AWS Re/Start
  </p>

  <p class="text-base pt-2 italic text-neutral-500 font-light">
    El nexo entre la infraestructura y la analítica de datos.
  </p>

  <a 
    href="https://nievesperez-data.github.io/" 
    target="_blank"
    class="text-lg font-medium border-b-2 border-black pb-1 mt-4 w-fit mb-10"
  >
    Nieves Pérez
  </a>

  <div 
    id="mobile-overlay-menu" 
    class="fixed inset-0 bg-neutral-50/98 z-40 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col items-center justify-center gap-10"
  >
    <span class="text-[11px] tracking-[0.4em] uppercase opacity-60 font-bold text-neutral-800">
      Cradle & Context
    </span>

    <div class="flex flex-col gap-8 items-center">
      <a 
        href="https://adalab.es/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-24 h-24 flex items-center justify-center border border-neutral-300 bg-white rounded-2xl shadow-md active:scale-95 transition-transform"
      >
        <img src={adalabLogo.src} alt="Logo Adalab" class="w-16 h-16 object-contain" />
      </a>

      <a 
        href="https://aws.amazon.com/es/training/restart/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-24 h-24 flex items-center justify-center border border-neutral-300 bg-white rounded-2xl shadow-md active:scale-95 transition-transform"
      >
        <img src={awsRestartLogo.src} alt="Logo AWS re/Start" class="w-16 h-16 object-contain" />
      </a>
    </div>

    <button 
      id="close-menu-btn"
      class="mt-10 px-6 py-2 bg-neutral-900 text-white rounded-lg text-sm font-semibold uppercase tracking-wider"
    >
      Cerrar
    </button>
  </div>
</section>

<script>
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const menu = document.getElementById('mobile-overlay-menu');
  
  openBtn?.addEventListener('click', () => {
    menu?.classList.remove('translate-x-full');
  });

  closeBtn?.addEventListener('click', () => {
    menu?.classList.add('translate-x-full');
  });
</script>
